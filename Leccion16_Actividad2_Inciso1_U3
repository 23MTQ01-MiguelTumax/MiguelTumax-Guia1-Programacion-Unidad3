//Arreglos con ciclos
//Problema - Un programa que almacene 10 notas del curso de programación
//y mostrar las notas ingresadas y el promedio de las notas
Algoritmo Leccion16_Actividad2_Inciso1_U3
	Definir notas, i Como Entero
	//Arreglo
	Dimensionar notas[10]
	
	//Solicitar las notas
	Para i = 1 Hasta 10 Con Paso 1 Hacer
		Escribir "Digite la nota ", i, ": " Sin Saltar
		Leer notas[i]
		promedio = notas[i] + promedio
	Fin Para
	
	
	Limpiar Pantalla
	Para i = 1 Hasta 10 Con Paso 1 Hacer
		Escribir "Nota ",i," : ", notas[i]
		Esperar 1 segundos
	Fin Para
	//Mostrar las notas
	
	Escribir "El promedio de las notas es: ", (promedio/10)
FinAlgoritmo
